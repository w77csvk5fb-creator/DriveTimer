# このファイルをコピーして .env.local を作成し、実際の値を入力してください。
# .env.local はgitignore対象です。手順の詳細はSETUP.mdを参照してください。

# クライアント側で使用（Google Cloud ConsoleでHTTPリファラー制限を必ず設定すること）
NEXT_PUBLIC_GOOGLE_MAPS_JS_API_KEY=REPLACE_ME_GOOGLE_MAPS_JS_API_KEY

# サーバー側(API Route)のみで使用。クライアントには送出されない
GOOGLE_DIRECTIONS_API_KEY=REPLACE_ME_GOOGLE_DIRECTIONS_API_KEY
GOOGLE_PLACES_API_KEY=REPLACE_ME_GOOGLE_PLACES_API_KEY

# Firebase Web設定（V2で使用。秘匿情報ではないが、flutterfire的にはfirebase initで取得する値）
NEXT_PUBLIC_FIREBASE_API_KEY=REPLACE_ME_FIREBASE_API_KEY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=REPLACE_ME_FIREBASE_AUTH_DOMAIN
NEXT_PUBLIC_FIREBASE_PROJECT_ID=REPLACE_ME_FIREBASE_PROJECT_ID
